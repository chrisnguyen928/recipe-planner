{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "target": "ES2024",
        "lib": ["ES2024", "DOM"],
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "typeRoots": ["./src/types", "./node_modules/@types"]
    }, 
    "include": ["src/**/*"],
    "exclude": ["drizzle.config.ts"]
}